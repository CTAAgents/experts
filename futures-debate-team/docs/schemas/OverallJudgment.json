{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "tendency": {
      "type": "string",
      "enum": [
        "bullish",
        "bearish",
        "neutral"
      ]
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "core_conflict": {
      "type": "string"
    },
    "suggested_position_pct": {
      "type": "number",
      "minimum": 0,
      "maximum": 100
    }
  },
  "required": [
    "tendency",
    "confidence",
    "core_conflict"
  ]
}