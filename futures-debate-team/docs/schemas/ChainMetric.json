{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ChainMetric",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "指标名 基差/仓单/持仓/期限结构"
    },
    "value": {
      "type": [
        "number",
        "string"
      ]
    },
    "change": {
      "type": "number",
      "description": "日/周环比"
    },
    "signal": {
      "type": "string",
      "enum": [
        "bullish",
        "bearish",
        "neutral"
      ]
    }
  },
  "required": [
    "name",
    "value",
    "signal"
  ]
}