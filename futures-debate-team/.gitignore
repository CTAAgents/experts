# Futures-Debate-Team Git忽略规则
# ================================

# ── 隐私凭证 ──
settings.json
settings.local.json
*.key
*.pem
secrets/
.env
**/.env

# ── API 密钥 ──
*api_key*
*apikey*
*token*
*secret*

# ── 数据缓存 ──
**/data/sentiment/sentiment_cache.json
**/data/cache/
**/reports/
reports/

# ── 数据库 ──
*.db
*.sqlite
*.sqlite3

# ── Python 缓存 ──
__pycache__/
*.pyc
*.pyo
.pytest_cache/

# ── 环境 ──
venv/
.venv/
virtualenv/

# ── 操作系统 ──
.DS_Store
Thumbs.db
*.swp
*.swo

# ── IDE ──
.vscode/
.idea/
*.code-workspace

# ── 日志 ──
*.log
logs/

# ── 生成的报告 ──
**/Reports/
**/reports/*.html
**/reports/*.json
