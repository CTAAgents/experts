# FDT Environment Variables Template
# Copy this file to .env and fill in your values

# LLM Configuration
FDT_LLM_API_KEY=your-api-key-here
FDT_LLM_API_BASE=https://api.deepseek.com/v1

# PostgreSQL Configuration (optional)
# FDT_PG_DSN=postgresql://user:pass@localhost:5432/fdt

# LangGraph Mode
# FDT_USE_LANGGRAPH=true

# Checkpointer Type
# FDT_CHECKPOINTER=sqlite
