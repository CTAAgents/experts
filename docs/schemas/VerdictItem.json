{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "dim": {
      "type": "string"
    },
    "ruling": {
      "type": "string",
      "enum": [
        "include",
        "watch",
        "exclude"
      ]
    },
    "winner": {
      "type": "string",
      "enum": [
        "bull",
        "bear"
      ]
    },
    "rebuttal_quality": {
      "type": "string",
      "enum": [
        "接住",
        "部分接住",
        "糊弄"
      ]
    },
    "reason": {
      "type": "string"
    }
  },
  "required": [
    "dim",
    "ruling",
    "rebuttal_quality",
    "reason"
  ]
}