{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ArgumentOutput",
  "description": "辩手输出 - 证真/慎思统一格式",
  "type": "object",
  "properties": {
    "version": {
      "type": "string",
      "enum": [
        "3.0"
      ]
    },
    "role": {
      "type": "string",
      "enum": [
        "证真",
        "慎思"
      ]
    },
    "variant": {
      "type": "string",
      "enum": [
        "bull",
        "bear"
      ]
    },
    "dimensions": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/DimensionItem"
      },
      "minItems": 5
    },
    "summary_4_risk": {
      "type": "string",
      "maxLength": 100
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "rebuttal_targets": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "required": [
    "version",
    "role",
    "dimensions",
    "confidence"
  ]
}