{
  "protocol": "A2A",
  "a2a_version": "1.0",
  "name": "Futures Debate Team (FDT)",
  "description": "期货辩论专家团 — 通道突破信号全流程辩论裁决系统。接收每日扫描信号，启动多Agent辩论，输出交易裁决与可执行方案。",
  "url": "file://~/.workbuddy/plugins/marketplaces/my-experts/plugins/futures-debate-team",
  "version": "2.2.0",
  "capabilities": {
    "skills": [
      {
        "id": "channel_breakout_scan",
        "name": "通道突破信号扫描",
        "description": "对62个国内期货品种执行DC20/DC55通道突破+布林带多因子扫描，输出排序信号。",
        "input": "scan_all.py --strategy channel_breakout (运行时无外部输入依赖)",
        "output": "scan_daily_{HHMM}_ranking_{YYYYMMDD}.html + scan_daily_{HHMM}_{YYYYMMDD}.json"
      },
      {
        "id": "multi_agent_debate",
        "name": "多Agent辩论裁决",
        "description": "对触发信号品种启动8名辩论专家（观澜、证真、慎思、闫判官、策执远、一致性裁判、风控明）进行全流程辩论，输出裁决与交易方案。",
        "input": "debate_results.json",
        "output": "debate_results.json + a2a_results.json"
      },
      {
        "id": "knowledge_extraction",
        "name": "辩论知识萃取",
        "description": "将辩论裁决中的高置信度逻辑关系萃取入库，积累交易知识。",
        "input": "debate_results.json",
        "output": "FDT memory/journal/debate_journal.json"
      }
    ],
    "streaming": false,
    "pushNotifications": false
  },
  "input": {
    "mimeType": "application/json",
    "schema": {
      "round_id": "string",
      "generated_at": "ISO 8601",
      "data_benchmark": "string",
      "signal_source": "string",
      "verdicts": {
        "symbol": {
          "direction": "BULL|BEAR|NEUTRAL",
          "action": "execute|hold|wait",
          "confidence": "高|中|低",
          "entry_price": "float|null",
          "stop_loss_price": "float|null",
          "target_price": "float|null",
          "position_size": "int|null",
          "contract": "string|null"
        }
      }
    }
  },
  "output": {
    "mimeType": "application/json",
    "schema": {
      "a2a_version": "1.0",
      "task": {
        "id": "string",
        "sessionId": "string",
        "status": "completed|failed",
        "parts": [
          {
            "type": "artifact",
            "artifact": {
              "id": "string",
              "name": "string",
              "contentType": "application/json",
              "content": {
                "symbol": "string",
                "decision": "BUY|SELL|WATCH|HOLD",
                "confidence": "float",
                "reasoning": "string"
              }
            }
          }
        ]
      }
    }
  },
  "keys": {
    "auth": "none",
    "scheme": ""
  }
}
